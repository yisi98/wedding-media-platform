# Local development environment — copy to .env before running
# DO NOT commit .env to git

APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Generate with: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your-event-password'))"
EVENT_PASSWORD_HASH=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

DATABASE_URL=postgresql+asyncpg://wedding_user:wedding_dev_password@localhost:5432/wedding_media
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=wedding-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

CORS_ORIGINS=http://localhost:3000
